# MongoDB connection string (Atlas or self-hosted replica set recommended so
# multi-document transactions work for trip dispatch / completion).
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/transitops?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=

# Port the API server listens on.
PORT=8080

# Comma-separated list of origins allowed to call this API (CORS).
# Use "*" to allow any origin (not recommended in production).
CORS_ORIGIN=*

# development | production
NODE_ENV=development
